generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model customers {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String
  phone           String?
  email           String?
  vehicle_details Json?
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  contact         String?
  vehicle         String?
  last_service    DateTime?      @db.Date
  total_spent     Decimal?       @default(0) @db.Decimal
  status          String?        @default("Active")
  appointments    appointments[]
  payments        payments[]

  @@schema("public")
}

model profiles {
  id         String     @id @db.Uuid
  full_name  String?    @db.VarChar
  email      String?    @db.VarChar
  role       user_role?
  avatar_url String?
  provider   String?    @db.VarChar
  created_at DateTime?  @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model employees {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name               String
  position           String
  department         String
  salary             Decimal?  @default(0) @db.Decimal
  status             String?   @default("Active")
  availability       String?   @default("Available")
  current_assignment String?   @default("None")
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  hire_date          DateTime? @db.Date

  @@schema("public")
}

model inventory_items {
  id                  String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                String
  category            String   @default("General")
  quantity            Int      @default(0)
  unit_price          Decimal  @default(0) @db.Decimal(10, 2)
  low_stock_threshold Int      @default(10)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @db.Timestamptz(6)
  stock_in            Int      @default(0)
  stock_out           Int      @default(0)
  unit                String   @default("pcs")

  @@schema("public")
}

model services {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String
  category   String
  duration   String
  price      Decimal   @db.Decimal
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model shop_settings {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_name  String?
  contact_number String?
  email          String?
  website        String?
  address        String?
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model transaction {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type        String
  description String
  amount      Decimal   @db.Decimal
  category    String
  date        DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model appointments {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customer_id        String    @db.Uuid
  service_type       String
  scheduled_date     DateTime  @db.Timestamptz(6)
  status             String    @default("Pending Verification")
  total_cost         Decimal   @db.Decimal
  deposit            Decimal?  @default(0) @db.Decimal
  remaining_balance  Decimal?  @default(0) @db.Decimal
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  employee_id        String?   @db.Uuid
  assigned_staff     String?
  notes              String?
  full_name          String?
  mobile_number      String?
  vehicle_make       String?
  vehicle_model      String?
  vehicle_year       String?  @default("")
  vehicle_class      String?
  vehicle_plate      String?
  payment_method     String?
  payment_type       String?
  addons             String?
  proof_url          String?
  approved_by        String?
  approved_at        DateTime? @db.Timestamptz(6)
  rejected_by        String?
  rejected_at        DateTime? @db.Timestamptz(6)
  rejection_reason   String?
  customer           customers  @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  payments           payments[]

  @@schema("public")
}

model payments {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customer_id    String        @db.Uuid
  appointment_id String?       @db.Uuid
  amount         Decimal       @db.Decimal(10, 2)
  payment_method String        @default("cash")
  status         String        @default("pending")
  created_at     DateTime?     @default(now()) @db.Timestamptz(6)
  appointment    appointments? @relation(fields: [appointment_id], references: [id])
  customer       customers     @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model part_requests {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  staff_id   String?  @db.Uuid
  staff_name String?
  item_id    String   @db.Uuid
  item_name  String
  category   String
  quantity   Int
  unit       String
  reason     String
  job_ref    String?
  note       String?
  status     String   @default("Pending")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model job_orders {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_no       String   @unique
  customer       String
  vehicle        String
  service        String
  assigned_staff String
  staff_id       String?  @db.Uuid
  scheduled_date DateTime @db.Date
  estimated_time String   @default("2 hours")
  status         String   @default("Pending")
  priority       String   @default("Normal")
  notes          String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model quote_requests {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String
  contact    String
  vehicle    String
  service    String
  size       String
  notes      String?
  status     String    @default("pending")
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

enum appointment_status {
  pending
  in_progress
  completed
  cancelled

  @@schema("public")
}

enum payment_method {
  cash
  card
  bank_transfer
  e_wallet

  @@schema("public")
}

enum user_role {
  admin
  staff
  customer
  frontdesk
  technician

  @@schema("public")
}